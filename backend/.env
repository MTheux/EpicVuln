# Database
DATABASE_URL="postgresql://vulncontrol:vulncontrol@localhost:5432/vulncontrol?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
